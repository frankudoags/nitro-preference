{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitropreferences"
  ],
  "ios": {
    "iosModuleName": "NitroPreferences"
  },
  "android": {
    "androidNamespace": [
      "nitropreferences"
    ],
    "androidCxxLibName": "NitroPreferences"
  },
  "autolinking": {
    "Preference": {
      "swift": "HybridPreference",
      "kotlin": "HybridPreference"
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
